# ------------------------------------------------------------------------------
# Nakama Example Environment Configuration
# ------------------------------------------------------------------------------
# Copy this file to '.env' and fill in the desired values.

# --- Required: AI Provider API Keys ---
# You must provide at least one API key depending on the provider you intend to use.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
NVIDIA_API_KEY=your_nvidia_nim_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# --- Optional: Provider URL Override ---
# Overrides the default base URL for the selected provider.
# Default for Anthropic: https://api.anthropic.com/v1
# Default for OpenAI: https://api.openai.com/v1
# Default for NVIDIA NIM: https://integrate.api.nvidia.com/v1
# URL=https://api.anthropic.com/v1

# --- Optional: Model Selection ---
# Specifies the exact model name to use. If not set, it will fallback based on keys.
# e.g., claude-3-5-sonnet-20241022, gpt-4o, moonshotai/kimi-k2.6
NAKAMA_MODEL=claude-3-5-sonnet-20241022

# --- Optional: Explicit Provider Selection ---
# Forces the provider logic (anthropic, openai, nim)
# NAKAMA_PROVIDER=anthropic

# --- Core Runtime Configuration ---
# Permission Mode: 'prompt' (interactive approval) or 'auto' (autonomous)
NAKAMA_PERMISSION_MODE=prompt

# Context Compaction Threshold
# Number of tokens before Nakama triggers transcript summarization
NAKAMA_COMPACTION_THRESHOLD=32000
